<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>UIRequiresFullScreen</key>
    <true/>
    <key>UIFileSharingEnabled</key>
    <true/>
    <key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>
    <key>NSCameraUsageDescription</key>
    <string>ZeroDark uses the camera for LiDAR scanning and visual identification.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>ZeroDark uses the microphone for voice synthesis and acoustic communications.</string>
    <key>NSHealthShareUsageDescription</key>
    <string>ZeroDark uses health data to learn activity and sleep patterns for personalized recommendations.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>ZeroDark may write health data to support activity tracking features.</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>ZeroDark uses location for mapping and navigation.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>ZeroDark uses location for tracking and emergency services.</string>
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>ZeroDark uses Bluetooth for mesh networking and LoRa communication.</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>ZeroDark uses local network for peer-to-peer mesh communication.</string>
    <key>NSMotionUsageDescription</key>
    <string>ZeroDark uses motion sensors for dead reckoning navigation and trail recording when GPS is unavailable.</string>
    <key>UIBackgroundModes</key>
    <array>
        <string>location</string>
        <string>bluetooth-central</string>
        <string>bluetooth-peripheral</string>
        <string>audio</string>
    </array>

    <!-- Declare .mbtiles / .pmtiles as known types so AirDrop and Files "Open In" route to ZeroDark -->
    <key>UTImportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>com.zerodark.mbtiles</string>
            <key>UTTypeDescription</key>
            <string>MBTiles Map Package</string>
            <key>UTTypeConformsTo</key>
            <array><string>public.database</string></array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array><string>mbtiles</string></array>
                <key>public.mime-type</key>
                <array><string>application/vnd.mapbox-mbtiles</string></array>
            </dict>
        </dict>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>com.zerodark.pmtiles</string>
            <key>UTTypeDescription</key>
            <string>PMTiles Map Archive</string>
            <key>UTTypeConformsTo</key>
            <array><string>public.data</string></array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array><string>pmtiles</string></array>
            </dict>
        </dict>
    </array>
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>MBTiles Map Package</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>com.zerodark.mbtiles</string>
                <string>public.database</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Owner</string>
        </dict>
        <dict>
            <key>CFBundleTypeName</key>
            <string>PMTiles Map Archive</string>
            <key>LSItemContentTypes</key>
            <array><string>com.zerodark.pmtiles</string></array>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Owner</string>
        </dict>
    </array>
</dict>
</plist>
